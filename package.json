{
  "name": "ai-application-toolkit",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:docs": "pnpm --filter @ai-application-toolkit/docs dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
