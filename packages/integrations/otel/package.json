{
  "name": "@ai-application-toolkit/otel",
  "version": "0.0.0",
  "description": "OpenTelemetry trace sink for the AI Application Toolkit — emit runtime execution as OTel spans.",
  "license": "MIT",
  "author": "Danny LAN <45042818+shaoyulan@users.noreply.github.com>",
  "homepage": "https://github.com/shaoyulan/ai-application-toolkit/tree/main/packages/integrations/otel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shaoyulan/ai-application-toolkit.git",
    "directory": "packages/integrations/otel"
  },
  "bugs": {
    "url": "https://github.com/shaoyulan/ai-application-toolkit/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "toolkit",
    "opentelemetry",
    "otel",
    "observability",
    "tracing"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-application-toolkit/trace": "workspace:*",
    "@opentelemetry/api": "^1.9.0"
  },
  "devDependencies": {
    "@ai-application-toolkit/guardrail": "workspace:*",
    "@ai-application-toolkit/runtime": "workspace:*",
    "@ai-application-toolkit/tool": "workspace:*",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
