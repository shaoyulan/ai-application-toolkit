{
  "name": "@ai-application-toolkit/codegraph",
  "version": "0.3.0",
  "description": "Turn a folder of source code into a queryable, multi-language code graph (symbols, imports, references) with LLM context ranking.",
  "license": "MIT",
  "author": "Danny LAN <45042818+shaoyulan@users.noreply.github.com>",
  "homepage": "https://github.com/shaoyulan/ai-application-toolkit/tree/main/packages/codegraph#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shaoyulan/ai-application-toolkit.git",
    "directory": "packages/codegraph"
  },
  "bugs": {
    "url": "https://github.com/shaoyulan/ai-application-toolkit/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "toolkit",
    "anthropic",
    "claude",
    "codegraph",
    "code-graph",
    "tree-sitter",
    "static-analysis",
    "repo-map"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "codegraph": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-application-toolkit/capability": "workspace:*",
    "@ai-application-toolkit/core": "workspace:*",
    "@ai-application-toolkit/tool": "workspace:*",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "web-tree-sitter": "^0.26.10"
  },
  "optionalDependencies": {
    "@ai-application-toolkit/mcp": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "untun": "^0.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
